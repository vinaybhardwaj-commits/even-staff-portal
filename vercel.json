{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["bom1"],
  "buildCommand": "next build",
  "installCommand": "npm install",
  "git": { "deploymentEnabled": { "main": true } },
  "crons": [
    {
      "path": "/api/cron/purge-soft-deleted",
      "schedule": "30 21 * * *"
    }
  ]
}
